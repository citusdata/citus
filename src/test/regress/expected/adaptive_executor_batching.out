 5
(5 rows)

--
-- Test 3: Batch size larger than result set (single batch)
--
SET citus.executor_batch_size TO 100000;
SELECT count(*) FROM batch_test;
 count
---------------------------------------------------------------------
   200
(1 row)

--
-- Test 4: Auto batch size (from work_mem)
