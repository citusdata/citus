    (TABLE tenant_4.citus_local_4) EXCEPT (TABLE regular_schema.old_data_coordinator)
    UNION
    (TABLE regular_schema.old_data_coordinator EXCEPT TABLE tenant_4.citus_local_4)
);
 ?column?
