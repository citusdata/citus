               ->  Sort
                     Sort Key: s.tenant_id
                     ->  Seq Scan on explain_src_7800205 s
               ->  Sort
                     Sort Key: i.tenant_id
                     ->  Seq Scan on explain_items_7800220 i
(13 rows)

