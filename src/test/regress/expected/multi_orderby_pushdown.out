CREATE TABLE sorted_merge_test (
    id int,
    val text,
    num numeric,
    ts timestamptz DEFAULT now()
);
CREATE TABLE
SELECT create_distributed_table('sorted_merge_test', 'id');
 create_distributed_table
--------------------------

(1 row)

