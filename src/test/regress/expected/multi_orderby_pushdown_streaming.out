WITH top_ids AS (
    SELECT id FROM sorted_merge_test ORDER BY id LIMIT 20
)
SELECT t.id, t.val
FROM sorted_merge_test t
JOIN top_ids ON t.id = top_ids.id
ORDER BY t.id
LIMIT 10;
