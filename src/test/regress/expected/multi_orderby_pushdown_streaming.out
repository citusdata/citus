-- G3: Cursor with backward scan
SET citus.enable_sorted_merge TO on;
BEGIN;
DECLARE sorted_cursor CURSOR FOR SELECT id FROM sorted_merge_test ORDER BY id;
FETCH 3 FROM sorted_cursor;
 id
---------------------------------------------------------------------
  1
  2
  3
(3 rows)

FETCH BACKWARD 1 FROM sorted_cursor;
psql:sql/multi_orderby_pushdown.sql.include:323: ERROR:  cursor can only scan forward
HINT:  Declare it with SCROLL option to enable backward scan.
FETCH 2 FROM sorted_cursor;
psql:sql/multi_orderby_pushdown.sql.include:324: ERROR:  current transaction is aborted, commands ignored until end of transaction block
CLOSE sorted_cursor;
psql:sql/multi_orderby_pushdown.sql.include:325: ERROR:  current transaction is aborted, commands ignored until end of transaction block
COMMIT;
