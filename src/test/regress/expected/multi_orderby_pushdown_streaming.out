-- G3: Cursor with backward scan
SET citus.enable_sorted_merge TO on;
BEGIN;
DECLARE sorted_cursor CURSOR FOR SELECT id FROM sorted_merge_test ORDER BY id;
FETCH 3 FROM sorted_cursor;
