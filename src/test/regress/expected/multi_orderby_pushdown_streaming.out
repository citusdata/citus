FETCH BACKWARD 1 FROM sorted_cursor;
 id
---------------------------------------------------------------------
  2
(1 row)

FETCH 2 FROM sorted_cursor;
 id
---------------------------------------------------------------------
  3
  4
(2 rows)

CLOSE sorted_cursor;
COMMIT;
